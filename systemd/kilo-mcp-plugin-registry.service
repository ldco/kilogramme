[Unit]
Description=Kilo MCP: Plugin Registry (@ :8214)
After=network-online.target

[Service]
ExecStart=%h/.npm-global/bin/mcp-proxy --port 8214 -- node %h/.config/kilo/mcp-servers/plugin-registry/dist/index.js
Restart=on-failure
RestartSec=5
Environment=PATH=%h/.npm-global/bin:%h/.local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
