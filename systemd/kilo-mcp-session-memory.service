[Unit]
Description=Kilo MCP: Session Memory (@ :8211)
After=network-online.target

[Service]
ExecStart=%h/.npm-global/bin/mcp-proxy --port 8211 -- node %h/.config/kilo/mcp-servers/session-memory/dist/index.js
Restart=on-failure
RestartSec=5
Environment=PATH=%h/.npm-global/bin:%h/.local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
