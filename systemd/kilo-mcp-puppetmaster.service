[Unit]
Description=Kilo MCP: Puppetmaster (proxy @ :8203)
After=network-online.target

[Service]
ExecStart=%h/.npm-global/bin/mcp-proxy --port 8203 -- %h/.npm-global/bin/tsx %h/.config/kilo/mcp-servers/puppetmaster/src/index.ts
Restart=on-failure
RestartSec=5
Environment=PATH=%h/.npm-global/bin:%h/.local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
